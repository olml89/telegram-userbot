{
    "name": "olml89/telegram-userbot-bot",
    "description": "Container to run isolated instances of MadelineProto API at demand by bot-manager through Redis messages.",
    "type": "project",
    "version": "1.0.0",
    "license": "proprietary",
    "authors": [
        {
            "name": "olml89"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": "^8.5",
        "ext-pcntl": "*",
        "ext-posix": "*",
        "ext-ffi": "*",
        "olml89/telegram-userbot-bot-runtime": "*",
        "danog/madelineproto": "^8.4"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../application",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../bot-runtime",
            "options": {
                "symlink": true
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "olml89\\TelegramUserbot\\Bot\\": "src/",
            "Tests\\Bot\\": "tests/"
        }
    }
}
