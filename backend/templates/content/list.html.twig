{% extends 'base.html.twig' %}

{% block title %}ContentLibrary - Admin Panel{% endblock %}

{% block body %}
    <div class="page-header">
        <div class="content-header">
            <h2>ContentLibrary</h2>
            <p>Manage your digital content and pricing.</p>
        </div>
        <div class="header-actions">
            <button class="btn btn-secondary btn-outline">$ Automatic price</button>
            <button class="btn btn-primary" data-content-open>+ Add new content</button>
        </div>
    </div>

    <div data-library-notifications></div>

    <div class="library-card">
        <div class="library-card-header">
            <div>
                <h3>Content ContentLibrary</h3>
                <p class="library-subtitle">Manage your content and pricing</p>
            </div>
        </div>

        <div class="library-filters" data-library-filters>
            <label for="contentSearch" class="sr-only">Search content</label>
            <input
                id="contentSearch"
                type="search"
                class="form-input search-input"
                placeholder="Search Content..."
                data-content-search
            />
            <div class="library-filter-group">
                <div data-library-category>
                    {% include 'common/components/select.html.twig' with {
                        defaultValue: 'All Categories',
                        options: categories|map(category => {
                            name: category.name,
                            value: category.publicId,
                        }),
                    } only %}
                </div>

                <div data-library-mode>
                    {% include 'common/components/select.html.twig' with {
                        defaultValue: 'All Modes',
                        options: modes,
                    } only %}
                </div>
            </div>
        </div>

        <div class="library-table">
            <table>
                <thead>
                <tr>
                    <th>Media</th>
                    <th>Content</th>
                    <th>Category</th>
                    <th>Bundle</th>
                    <th>Price</th>
                    <th>Sales</th>
                    <th>Status</th>
                    <th>Created At</th>
                    <th></th>
                </tr>
                </thead>
                <tbody data-library-table-body>
                {% for content in contents %}
                    <tr class="content-item" data-content-row>
                        <td>
                            {%
                                set thumbnailFiles = content.files.list
                                    |filter(file => file.hasThumbnail ?? false)
                                    |slice(0, 4)
                            %}
                            {%
                                set nonThumbnailFiles = content.files.list
                                    |filter(file => not (file.hasThumbnail ?? false))
                                    |slice(0, 4 - thumbnailFiles|length)
                            %}
                            {% set totalFiles = content.files.list|length %}

                            {% set mediaClass =
                                totalFiles == 1 ? 'media-single' :
                                totalFiles == 2 ? 'media-pair' :
                                'media-grid'
                            %}

                            <div class="media-thumb {{ mediaClass }}">
                                {% for thumbnailFile in thumbnailFiles %}
                                    <img src="/api/files/{{ thumbnailFile.publicId }}/thumbnail" alt="Media thumbnail" class="media-img">
                                {% endfor %}

                                {% for nonThumbnailFile in nonThumbnailFiles %}
                                    <span class="placeholder">
                                        {% if nonThumbnailFile.mimeType starts with 'audio/' %}
                                            🎵
                                        {% elseif nonThumbnailFile.mimeType starts with 'text/plain' or nonThumbnailFile.mimeType starts with 'application/pdf' %}
                                            📄
                                        {% else %}
                                            📦
                                        {% endif %}
                                    </span>
                                {% endfor %}

                                {% if totalFiles > 4 %}
                                    <span class="media-more">+{{ totalFiles - 4 }}</span>
                                {% endif %}
                            </div>
                        </td>
                        <td>
                            <div class="content-info">
                                <div class="content-title">{{ content.title }}</div>
                                <div class="content-description">{{ content.description }}</div>
                                <div class="tag-list">
                                    {% for tag in content.tags %}
                                        <span class="tag">{{ tag.name }}</span>
                                    {% endfor %}
                                </div>
                            </div>
                        </td>
                        <td><span class="pill">{{ content.category.name }}</span></td>
                        <td>
                            <span class="bundle">
                                Images {{ content.files.count.images }} ·
                                Videos {{ content.files.count.videos }} ·
                                Audio {{ content.files.count.audios }} ·
                                Docs {{ content.files.count.documents }}
                            </span>
                        </td>
                        <td>
                            <div class="price-info">
                                <div class="price-value">${{ content.price }}</div>
                                <span class="pill pill-muted">{{ content.mode.label() }}</span>
                            </div>
                        </td>
                        <td>{{ content.sales }}</td>
                        <td>
                            {% set statusClass = (content.status.value is same as('active')) ? 'pill-active' : 'pill-inactive' %}
                            <span class="pill {{ statusClass }}">{{ content.status.label() }}</span>
                        </td>
                        <td>{{ content.createdAt|date('Y/m/d, H:i:s') }}</td>
                        <td>
                            <div class="actions-menu">
                                <button class="actions-menu-trigger" type="button" aria-label="More actions">⋯</button>
                                <div class="actions-menu-dropdown">
                                    <button type="button" class="action-item" data-preview-open>
                                        <span class="action-icon">👁️</span>
                                        Preview
                                    </button>
                                    <button type="button" class="action-item">
                                        <span class="action-icon">📝</span>
                                        Edit
                                    </button>
                                    <button type="button" class="action-item">
                                        <span class="action-icon">🗐</span>
                                        Duplicate
                                    </button>
                                    <button type="button" class="action-item action-danger">
                                        <span class="action-icon">🗑️</span>
                                        Delete
                                    </button>
                                </div>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>

        <div class="library-footer">
            <span class="library-count" data-library-counter>
                <span data-library-counter-empty hidden>No content found</span>
                <span data-library-counter-count></span>
            </span>
            <div class="library-pagination" data-library-pagination>
                <script>
                    window.paginationData = {{ contents|json_encode|raw }}
                </script>
                <button
                    class="btn btn-secondary btn-hover-outline btn-sm"
                    data-library-pagination-previous
                >Previous</button>
                <span class="page-indicator" data-library-pagination-page></span>
                <button
                    class="btn btn-secondary btn-hover-outline btn-sm"
                    data-library-pagination-next
                >Next</button>
            </div>
        </div>
    </div>

    {% include 'content/add.html.twig' with {
