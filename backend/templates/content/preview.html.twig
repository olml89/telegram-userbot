<div id="contentPreviewModal" class="modal{% if is_active %} is-active{% endif %}">
    <div class="modal-content modal-lg">
        <div class="modal-header">
            <div>
                <h3>Content Preview</h3>
                <p class="modal-subtitle">Preview of <strong><span data-content-title></span></strong></p>
            </div>
            <button class="close-modal" type="button" data-preview-content-close aria-label="Close">&times;</button>
        </div>

        <div class="modal-body">
            <div class="modal-section details-grid">
                <div class="details-panel">
                    <h4>Content Details</h4>
                    <div class="detail-row"><strong>Title:</strong> <span data-content-title></span></div>
                    <div class="detail-row"><strong>Category:</strong> <span data-content-category></span></div>
                    <div class="detail-row"><strong>Mode:</strong> <span data-content-mode></span></div>
                    <div class="detail-row"><strong>Price:</strong> <span data-content-price></span>$</div>
                    <div class="detail-row"><strong>Intensity:</strong> <span data-content-intensity></span>%</div>
                    <div class="detail-row"><strong>Language:</strong> <span data-content-language></span></div>
                    <div class="detail-row"><strong>Status:</strong> <span data-content-status></span></div>
                </div>

                <div class="details-panel">
                    <h4>Library Summary</h4>
                    <div class="detail-row"><strong>Files:</strong> <span data-content-file-count></span></div>
                    <div class="detail-row"><strong>Total size:</strong> <span data-content-size></span></div>
                    <div class="detail-row"><strong>Created:</strong> <span data-content-created></span></div>
                    <div class="detail-row"><strong>Sales:</strong> <span data-content-sales></span></div>
                </div>
            </div>

            <div class="modal-section">
                <h4>Description</h4>
                <p class="section-subtitle" data-content-description></p>
            </div>

            <div class="modal-section">
                <h4>Tags</h4>
                <div class="tag-list" data-content-tags></div>
            </div>

            <div class="modal-section">
                <h4>Files</h4>

                <form class="file-list" data-content-files></form>
            </div>
        </div>

        <div class="modal-footer">
            <button type="button" class="btn btn-secondary btn-hover-outline" data-preview-content-close>Close</button>
        </div>
    </div>
</div>
