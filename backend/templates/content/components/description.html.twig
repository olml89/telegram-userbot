<label class="form-label full-width" data-content-description>
    <span class="form-label-title" data-error-for="description">Description</span>
    <textarea
        name="description"
        {% if minLength is defined and minLength is not null %}minlength="{{ minLength }}"{% endif %}
        {% if maxLength is defined and maxLength is not null %}maxLength="{{ maxLength }}"{% endif %}
        class="form-textarea"
        rows="3"
        placeholder="Write a short description..."
        data-text-input
        {% if required|default(false) %}required{% endif %}></textarea>
</label>
