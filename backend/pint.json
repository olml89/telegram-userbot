{
    "preset": "per",
    "rules": {
        "method_argument_space": false,
        "ordered_imports": {
            "sort_algorithm": "alpha"
        }
    },
    "paths": [
        "bin",
        "migrations",
        "public",
        "src",
        "tests"
    ],
    "exclude": [
        "assets",
        "config",
        "doc",
        "node_modules",
        "php-fpm",
        "public/build",
        "templates",
        "var",
        "vendor"
    ]
}
