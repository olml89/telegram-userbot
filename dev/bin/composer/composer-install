#!/bin/sh
set -eu

echo "🔧 Installing dependencies (environment: ${APP_ENV})"

if [ $# -eq 0 ]; then
  echo "❌ No services provided"
  exit 1
fi

for SERVICE in "$@"; do
	case "$SERVICE" in
		application|bot-runtime|bot|bot-manager|backend|dev)
			WORKING_DIR="/telegram-userbot/$SERVICE";

			if [ -d "$WORKING_DIR/vendor" ]; then
				echo "🟢 [$SERVICE] Dependencies already installed"
				continue;
			fi

            echo "⚪ [$SERVICE] Installing dependencies..."

			# Build arguments
            set -- composer install \
                --no-interaction \
                --no-progress \
                --optimize-autoloader \
                --working-dir="$WORKING_DIR"

            if [ "$APP_ENV" = "dev" ]; then
                set -- "$@" --prefer-dist
            fi

            if [ "$APP_ENV" = "prod" ]; then
                set -- "$@" --no-dev
            fi

			if [ "$APP_ENV" = "ci" ]; then
				set -- "$@" --ignore-platform-reqs
			fi

            printf '🔍 [%s] %s\n' "$SERVICE" "$*"
            "$@"

            echo "🟢 [$SERVICE] Dependencies successfully installed"
			;;
		*)
			echo "❌ Unknown service: $SERVICE"
			exit 1
			;;
	esac
done

echo "✅ Dependencies successfully installed"
