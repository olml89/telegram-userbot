#!/bin/sh

# Execute the pre-commit script inside the container, that launches validate-commit.sh
if ! make commit; then
    echo "❌ Pre-commit checks failed. Commit aborted."
    exit 1
fi

# Stage any changes the sync made (on the host, where git lives)
if ! git diff --quiet dev/composer.json 2>/dev/null; then
    echo "📦 dev/composer.json was updated with new platform requirements. Staging changes..."
    git add dev/composer.json
fi

echo "✅ All checks have passed. Proceeding with the commit."
